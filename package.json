{
  "author": "Daniele Viganò",
  "description": "A vanilla JS lightweight (zero dependencies) library to read, write and delete cookies in the browser.",
  "devDependencies": {
    "microbundle": "^0.15.1"
  },
  "exports": {
    "default": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/daniele-vigano/cf-simple-cookie",
  "keywords": [
    "javascript cookie",
    "browser cookie management",
    "vanilla js cookie",
    "cookie library",
    "javascript cookie parser",
    "cookie helper",
    "lightweight cookie",
    "zero dependencies",
    "es6 cookie",
    "cookie manipulation",
    "set cookie javascript",
    "get cookie javascript",
    "delete cookie javascript"
  ],
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.module.js",
  "name": "cf-simple-cookie",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daniele-vigano/cf-simple-cookie.git"
  },
  "scripts": {
    "build": "microbundle",
    "dev": "microbundle watch --no-compress --format modern",
    "prepublishOnly": "npm run build"
  },
  "source": "src/index.js",
  "type": "module",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.umd.js",
  "version": "1.2.10"
}
