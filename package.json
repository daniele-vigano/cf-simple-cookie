{
  "name": "cf-simple-cookie",
  "version": "1.2.7",
  "files": [
    "dist"
  ],
  "description": "A vanilla JS lightweight (zero dependencies) library to read, write and delete cookies in the browser.",
  "homepage": "https://daniele-vigano.github.io/cf-simple-cookie/",
  "type": "module",
  "source": "src/index.js",
  "main": "./dist/index.cjs",
  "module": "./dist/index.module.js",
  "unpkg": "./dist/index.umd.js",
  "exports": {
    "require": "./dist/index.cjs",
    "default": "./dist/index.js"
  },
  "scripts": {
    "build": "microbundle",
    "dev": "microbundle watch --no-compress --format modern"
  },
  "keywords": [
    "cookie",
    "browser",
    "read",
    "write",
    "delete",
    "simple cookie",
    "javascript",
    "vanilla"
  ],
  "author": "Daniele Viganò",
  "license": "MIT",
  "devDependencies": {
    "microbundle": "^0.15.1"
  }
}